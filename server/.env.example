# Copy this to .env for local development.
# On Railway, set these in the "Variables" tab — do NOT commit .env to GitHub.

# Local MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=game_library
DB_PORT=3307

# Railway automatically injects MYSQLHOST, MYSQLUSER, etc.
# The db.js file handles both cases automatically.

PORT=5000
